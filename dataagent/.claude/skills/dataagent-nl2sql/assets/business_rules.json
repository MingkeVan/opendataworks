{
  "schema_version": "1.0",
  "items": [
    {
      "term": "活跃用户",
      "synonyms": [
        "DAU",
        "日活"
      ],
      "definition": "若用户未说明活跃行为，默认不能直接计算，必须追问是登录、访问、下单还是其他事件。"
    },
    {
      "term": "趋势分析",
      "synonyms": [
        "走势",
        "变化趋势"
      ],
      "definition": "未指定时间粒度时默认按天；若时间跨度较长可建议按周或按月汇总。"
    },
    {
      "term": "对比分析",
      "synonyms": [
        "横向对比",
        "分组对比"
      ],
      "definition": "默认要求对比项使用相同时间范围、相同过滤条件和相同统计口径。"
    },
    {
      "term": "订单金额",
      "synonyms": [
        "GMV",
        "成交额"
      ],
      "definition": "若未说明，需确认是否统计已支付订单、是否扣除退款、是否含取消订单。"
    }
  ]
}
